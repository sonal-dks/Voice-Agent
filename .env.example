# =============================================================================
# Voice Agent — environment template (copy to repository root as `.env`)
#   cp .env.example .env
#
# Commit only this file. Never commit `.env` or real keys.
# Production: Vercel → Project → Environment Variables.
#
# IMPORTANCE (for this repo’s Next + scheduling code today):
#   [R] Required     — app breaks or feature is disabled without it
#   [I] Important    — needed for full product (booking, email, PII); optional for “chat only”
#   [O] Optional     — has a safe default or only tweaks behavior
#   [P] Placeholder  — documented for future phases; not read by current app code
#
# Phase 1 = Groq LLM chat. Phase 2 = Sheets/Calendar/MCP tools. Phase 3+ = Gmail/PII/voice.
# =============================================================================

# --- Phase 1 — Groq LLM (OpenAI-compatible API) -------------------------------
# [R] Groq API key — https://console.groq.com/keys — without it, chat uses offline stub replies only.
GROQ_API_KEY=

# [O] Model id — see https://console.groq.com/docs/models
GROQ_MODEL=llama-3.3-70b-versatile

# [O] Max wait per LLM request (ms). Code enforces a floor (~5s); 60000 is safe for tool calls.
LLM_TIMEOUT_MS=60000

# [O] Extra attempts after HTTP 429 (backoff). 0–8, default 3.
LLM_MAX_RETRIES=3

# [P] Reserved — not read by app code yet; safe to omit.
LOG_LEVEL=INFO

# [P] Public site URL for links in emails/redirects — set before production; not referenced in lib/ yet.
NEXT_PUBLIC_APP_URL=https://your-project.vercel.app

# --- MCP advisor server (stdio) -----------------------------------------------
# [I] Path or command so Next can spawn the scheduling MCP (see lib/mcp/schedulingMcpClient.ts).
#     If unset, live slot lookup / booking tools fall back or skip depending on code paths.
MCP_ADVISOR_SERVER_ENTRY=

# [O] Force in-process scheduling (same as Vercel). Use locally to debug without stdio MCP.
#     On Vercel, VERCEL=1 is set automatically and stdio MCP is skipped (avoids "Connection closed").
# ADVISOR_SCHEDULING_DIRECT=1

# --- Google — Sheets + Calendar (MCP / scheduling) -----------------------------
# [I] Spreadsheet id from the URL (the long id between /d/ and /edit).
GOOGLE_SHEETS_SPREADSHEET_ID=

# [O] Tab names — match your workbook (defaults shown).
GOOGLE_SHEETS_TAB_BOOKINGS=Bookings
# [O] Advisor pre-booking log tab (default "Advisor Pre-Bookings"). Many workbooks use "Notes" instead:
# GOOGLE_SHEETS_TAB_ADVISOR_PREBOOKINGS=Notes

# [I] Service account JSON — MUST be one line (minified) OR base64 of the full JSON.
#     Do not use multiline `{ ... }` in .env: the MCP subprocess often receives a truncated value → JSON parse errors.
#     Minify:  npm run minify:service-account -- path/to/key.json   → paste output as the value (one line).
GOOGLE_SERVICE_ACCOUNT_JSON=

# [I] Calendar to read/write for availability (often advisor email or calendar id).
GOOGLE_CALENDAR_ID=

# [O] Slot length in minutes.
SLOT_DURATION_MINUTES=30

# [O] IANA timezone for advisor slots.
ADVISOR_TIMEZONE=Asia/Kolkata

# --- PII sheet + encryption (post-call / submit flows) ------------------------
# [O] Worksheet tab for encrypted PII rows.
GOOGLE_SHEETS_TAB_PII=PII_Submissions

# [I] When PII encryption is enabled in code paths — 64 hex chars (32 bytes AES-256).
#     Generate a fresh key:  openssl rand -hex 32
#     Do not change after data is encrypted with an old key (you cannot decrypt old rows).
PII_ENCRYPTION_KEY=

# [O] Rate limits for PII submit API (phase-3-post-call-pii).
RATE_LIMIT_PII_PER_CODE=5
RATE_LIMIT_PII_PER_IP=100

# --- Gmail — choose ONE auth path ------------------------------------------------
#
# (A) Personal Gmail (@gmail.com) — OAuth 2.0 user credentials (recommended for individuals).
#     If these three are set, they take precedence over Workspace delegation.
#     Obtain refresh token:  cd phase-2-scheduling-core && npm run gmail:oauth-token
#     GCP: OAuth client (Desktop or Web), Gmail API enabled; redirect URI must match.
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REFRESH_TOKEN=
# Must match the redirect URI registered for that OAuth client (e.g. http://localhost:3005/oauth2/callback).
GMAIL_OAUTH_REDIRECT_URI=http://localhost:3005/oauth2/callback
# The Gmail address you signed in with when authorizing (used as RFC822 From: for drafts/sends).
GMAIL_OAUTH_USER_EMAIL=

# (B) Google Workspace — service account + domain-wide delegation (no consumer @gmail.com).
#     Leave OAuth vars empty. JWT uses GOOGLE_SERVICE_ACCOUNT_JSON + subject below.
GMAIL_DELEGATED_USER=

# [I] Where advisor notifications / draft recipients go.
ADVISOR_INBOX_EMAIL=

# [O] Text blurb in user confirmation emails (name, how to reach advisor).
ADVISOR_PUBLIC_DETAILS=Advisor name and contact blurb for user confirmation email.

# --- Browser voice (Phase 4 — wired to /api/agent/stream) --------------------
# [R*] Deepgram — single API key for both STT (listen) and TTS (speak). https://console.deepgram.com
#      Without this key, voice mode is disabled; text chat still works.
DEEPGRAM_API_KEY=

# [O] Deepgram Aura TTS voice model (query param on /v1/speak). See Deepgram TTS model list in docs.
#     Default: aura-2-thalia-en
# DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# --- Twilio PSTN (optional future) --------------------------------------------
# [P] Only if you add phone ingress; not used by default Next chat UI.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# --- Reserved (optional future) -----------------------------------------------
# [P] Only if you add PostgreSQL later; default design is Sheets-only — leave unset.
# DATABASE_URL=
